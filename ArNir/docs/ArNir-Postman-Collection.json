{
  "info": {
    "name": "ArNir Enterprise AI Platform — Full API",
    "description": "Complete Postman collection covering all 12 ArNir.API controllers and 30+ endpoints.\n\nBase URL: https://localhost:5000\n\nFrontend improvement status: Phases 1-8 complete. Phase 7 added SSE streaming (GET /api/rag/stream). Phase 8 migrated @arnir/shared to strict TypeScript (56 files).\n\nUpdated: Phase 8 TypeScript migration (March 2026)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:5000" }
  ],
  "item": [
    {
      "name": "RAG",
      "item": [
        {
          "name": "Run RAG Query",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/rag/run",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"What is cloud computing?\",\n  \"topK\": 3,\n  \"useHybrid\": true,\n  \"promptStyle\": \"rag\",\n  \"provider\": \"OpenAI\",\n  \"model\": \"gpt-4o-mini\"\n}"
            }
          }
        },
        {
          "name": "Stream RAG Query (SSE)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/rag/stream?query=What is cloud computing?&topK=3&useHybrid=true&promptStyle=rag&provider=OpenAI&model=gpt-4o-mini",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rag", "stream"],
              "query": [
                { "key": "query", "value": "What is cloud computing?" },
                { "key": "topK", "value": "3" },
                { "key": "useHybrid", "value": "true" },
                { "key": "promptStyle", "value": "rag" },
                { "key": "provider", "value": "OpenAI" },
                { "key": "model", "value": "gpt-4o-mini" }
              ]
            },
            "description": "Server-Sent Events (SSE) endpoint. Streams completed RAG answer as incremental token events. Final event includes historyId and retrieved chunks. Content-Type: text/event-stream."
          }
        }
      ]
    },
