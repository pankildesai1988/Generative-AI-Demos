@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="card auth-card border-0 mt-4 text-center">
    <div class="card-body p-5">
        <i class="fas fa-ban fa-4x text-danger mb-3"></i>
        <h4 class="text-danger">Access Denied</h4>
        <p class="text-muted">You do not have permission to view this page.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary mt-2">
            <i class="fas fa-sign-in-alt me-1"></i> Back to Login
        </a>
    </div>
</div>
