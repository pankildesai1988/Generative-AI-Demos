@model ArNir.RAG.Hosting.IngestionQueue
@{
    ViewData["Title"] = "Job Monitor";
}

<div class="content-header">
    <div class="container-fluid">
        <h1 class="m-0">Background Job Monitor</h1>
        <small class="text-muted">Real-time ingestion queue status — refreshes every 3 seconds.</small>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        <!-- Queue Depth Card -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card text-white bg-primary">
                    <div class="card-body d-flex align-items-center">
                        <i class="fas fa-layer-group fa-3x me-3"></i>
                        <div>
                            <div id="queueDepthBadge" class="display-4 fw-bold">@Model.QueueDepth</div>
                            <div class="small">Jobs in Queue</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-success">
                    <div class="card-body d-flex align-items-center">
                        <i class="fas fa-check-circle fa-3x me-3"></i>
                        <div>
                            <div id="successCountBadge" class="display-4 fw-bold">0</div>
                            <div class="small">Recent Successes</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-danger">
                    <div class="card-body d-flex align-items-center">
                        <i class="fas fa-times-circle fa-3x me-3"></i>
                        <div>
                            <div id="failCountBadge" class="display-4 fw-bold">0</div>
                            <div class="small">Recent Failures</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Jobs Table -->
        <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h5 class="card-title mb-0"><i class="fas fa-list-alt me-2"></i>Recent Job Results</h5>
                <small class="text-muted" id="lastUpdated">—</small>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-sm">
                        <thead>
                            <tr>
                                <th>Document</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Chunks</th>
                                <th class="text-center">Embeddings</th>
                                <th>Error</th>
                                <th>Completed At</th>
                            </tr>
                        </thead>
                        <tbody id="jobResultsBody">
                            <tr><td colspan="6" class="text-center text-muted">Loading…</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</section>

@section Scripts {
<script>
    function updateDashboard(data) {
        // Update queue depth
        document.getElementById('queueDepthBadge').textContent = data.queueDepth;

        const results = data.recentResults || [];
        const successCount = results.filter(r => r.success).length;
        const failCount    = results.filter(r => !r.success).length;
        document.getElementById('successCountBadge').textContent = successCount;
        document.getElementById('failCountBadge').textContent    = failCount;

        // Build table rows
        const tbody = document.getElementById('jobResultsBody');
        if (results.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">No recent jobs.</td></tr>';
            return;
        }

        tbody.innerHTML = results.map(r => `
            <tr>
                <td><span title="${r.documentName}">${r.documentName.length > 40 ? r.documentName.substring(0, 40) + '…' : r.documentName}</span></td>
                <td class="text-center">
                    ${r.success
                        ? '<span class="badge bg-success">&#10003; OK</span>'
                        : '<span class="badge bg-danger">&#10007; Failed</span>'}
                </td>
                <td class="text-center">${r.chunksCreated}</td>
                <td class="text-center">${r.embeddingsCreated}</td>
                <td><small class="text-danger">${r.error ?? ''}</small></td>
                <td><small>${r.completedAt}</small></td>
            </tr>
        `).join('');

        document.getElementById('lastUpdated').textContent =
            'Last updated: ' + new Date().toLocaleTimeString();
    }

    function pollStatus() {
        fetch('/JobMonitor/Status')
            .then(r => r.json())
            .then(data => updateDashboard(data))
            .catch(() => {
                document.getElementById('lastUpdated').textContent = 'Error fetching status';
            });
    }

    // Initial load + poll every 3 seconds
    pollStatus();
    setInterval(pollStatus, 3000);
</script>
}
