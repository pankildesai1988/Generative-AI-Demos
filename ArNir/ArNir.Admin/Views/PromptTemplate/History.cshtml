@model IEnumerable<ArNir.Core.Entities.PromptTemplateEntity>
@{
    var style = ViewBag.Style as string ?? "unknown";
    ViewData["Title"] = $"Version History: {style}";
    var versions = Model.ToList();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Version History: <span class="badge bg-info">@style</span></h1>
            </div>
            <div class="col-sm-6 text-end">
                <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>Back to Templates</a>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<section class="content">
    <div class="container-fluid">
        @if (!versions.Any())
        {
            <div class="alert alert-info">No versions found for style "@style".</div>
        }
        else
        {
            <!-- Compare selector -->
            <div class="card mb-3">
                <div class="card-header"><strong><i class="fas fa-columns me-1"></i> Compare Versions</strong></div>
                <div class="card-body">
                    <form asp-action="Compare" method="get" class="row g-2 align-items-end">
                        <div class="col-auto">
                            <label class="form-label">Left Version</label>
                            <select name="id1" class="form-select">
                                @foreach (var v in versions)
                                {
                                    <option value="@v.Id">v@v.Version — @v.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-auto">
                            <label class="form-label">Right Version</label>
                            <select name="id2" class="form-select">
                                @{ var secondDefault = versions.Skip(1).FirstOrDefault(); }
                                @foreach (var v in versions)
                                {
                                    if (v.Id == secondDefault?.Id)
                                    {
                                        <option value="@v.Id" selected>v@v.Version — @v.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@v.Id">v@v.Version — @v.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary"><i class="fas fa-exchange-alt me-1"></i>Compare</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Version Timeline -->
            <div class="card">
                <div class="card-header"><strong><i class="fas fa-history me-1"></i> Timeline</strong></div>
                <div class="card-body p-0">
                    <table class="table table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:80px">Version</th>
                                <th>Name</th>
                                <th style="width:80px">Status</th>
                                <th>Template Preview</th>
                                <th style="width:160px">Created</th>
                                <th style="width:160px">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in versions)
                            {
                                <tr class="@(v.IsActive ? "table-success" : "")">
                                    <td>
                                        <strong>v@v.Version</strong>
                                    </td>
                                    <td>@v.Name</td>
                                    <td>
                                        @if (v.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <code class="small" title="@v.TemplateText">@(v.TemplateText.Length > 120 ? v.TemplateText[..120] + "..." : v.TemplateText)</code>
                                    </td>
                                    <td>@v.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        @if (!v.IsActive)
                                        {
                                            <form asp-action="Rollback" asp-route-id="@v.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('Restore v@(v.Version) as the active version?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-warning" title="Rollback to this version">
                                                    <i class="fas fa-undo"></i> Rollback
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Current</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</section>
