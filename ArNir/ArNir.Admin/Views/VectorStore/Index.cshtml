@model ArNir.Admin.Models.VectorStoreViewModel
@{
    ViewData["Title"] = "Vector Store Health";
}

@if (TempData["Success"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            showToast('@Html.Raw(TempData["Success"])', 'success');
        });
    </script>
}
@if (TempData["Error"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            showToast('@Html.Raw(TempData["Error"])', 'error');
        });
    </script>
}

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-layer-group fa-2x me-3"></i>
                <div>
                    <div class="fs-3 fw-bold">@Model.TotalEmbeddings</div>
                    <div class="small">Total Embeddings</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-info">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-exclamation-triangle fa-2x me-3"></i>
                <div>
                    <div class="fs-3 fw-bold">@Model.OrphanedDocuments.Count</div>
                    <div class="small">Orphaned Documents</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card @(Model.LastIndexedAt.HasValue ? "bg-success" : "bg-secondary") text-white">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-clock fa-2x me-3"></i>
                <div>
                    <div class="fs-6 fw-bold">
                        @(Model.LastIndexedAt.HasValue ? Model.LastIndexedAt.Value.ToString("yyyy-MM-dd HH:mm") : "Never")
                    </div>
                    <div class="small">Last Indexed</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Embeddings by Model -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="fas fa-brain me-2"></i>Embeddings by Model</h5>
            </div>
            <div class="card-body">
                @if (Model.EmbeddingsByModel.Any())
                {
                    <table id="modelTable" class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Model</th>
                                <th class="text-end">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.EmbeddingsByModel)
                            {
                                <tr>
                                    <td><code>@m.Model</code></td>
                                    <td class="text-end fw-bold">@m.Count.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No embeddings indexed yet.</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Orphaned Documents -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title mb-0"><i class="fas fa-exclamation-circle me-2 text-warning"></i>Orphaned Documents</h5>
        <small class="text-muted">Documents with chunks missing from the vector store</small>
    </div>
    <div class="card-body">
        @if (Model.OrphanedDocuments.Any())
        {
            <table id="orphanTable" class="table table-striped">
                <thead>
                    <tr>
                        <th>Document ID</th>
                        <th>Document Name</th>
                        <th>Missing Chunks</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model.OrphanedDocuments)
                    {
                        <tr>
                            <td>@doc.DocumentId</td>
                            <td>@doc.DocumentName</td>
                            <td><span class="badge bg-danger">@doc.MissingChunks</span></td>
                            <td>
                                <form asp-action="RebuildForDocument" asp-controller="VectorStore" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                    <button type="submit" class="btn btn-sm btn-warning"
                                            onclick="return confirm('Rebuild embeddings for \'@doc.DocumentName\'?')">
                                        <i class="fas fa-sync-alt me-1"></i>Rebuild
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle me-2"></i>
                All document chunks are indexed in the vector store. No orphans detected.
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            if ($('#orphanTable tbody tr').length > 0) {
                $('#orphanTable').DataTable({ paging: true, searching: true });
            }
        });
    </script>
}
