<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - ArNir Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- AdminLTE CSS -->
    <link rel="stylesheet" href="~/lib/admin-lte/css/adminlte.min.css" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

    <!-- Data Tables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
</head>
<body class="layout-fixed sidebar-expand-lg sidebar-open bg-body-tertiary">
    <!--begin::App Wrapper-->
    <div class="app-wrapper">
        <!--begin::Header-->
        <nav class="app-header navbar navbar-expand bg-body">
            <!--begin::Container-->
            <div class="container-fluid">
                <!--begin::Start Navbar Links-->
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                            <i class="bi bi-list"></i>
                        </a>
                    </li>
                    <li class="nav-item d-none d-md-block"><a href="/" class="nav-link">Home</a></li>
                </ul>
                <!--end::Start Navbar Links-->
                <!--begin::End Navbar Links-->
                <ul class="navbar-nav ms-auto">
                    <!--begin::Navbar Search-->
                    <li class="nav-item">
                        <a class="nav-link" data-widget="navbar-search" href="#" role="button">
                            <i class="bi bi-search"></i>
                        </a>
                    </li>
                    <!--end::Navbar Search-->
                    <!--begin::Fullscreen Toggle-->
                    <li class="nav-item">
                        <a class="nav-link" href="#" data-lte-toggle="fullscreen">
                            <i data-lte-icon="maximize" class="bi bi-arrows-fullscreen"></i>
                            <i data-lte-icon="minimize" class="bi bi-fullscreen-exit" style="display: none"></i>
                        </a>
                    </li>
                    <!--end::Fullscreen Toggle-->
                    <!--begin::Notification Bell-->
                    <li class="nav-item d-inline-block me-1">
                        <div class="dropdown d-inline-block">
                            <button class="btn btn-link text-dark p-0 nav-link position-relative"
                                    data-bs-toggle="dropdown" aria-expanded="false"
                                    id="notifBtn" onclick="loadNotifications()">
                                <i class="fas fa-bell fa-lg"></i>
                                <span id="notifBadge"
                                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                      style="display:none; font-size:0.65rem;">0</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow"
                                style="min-width:320px; max-width:400px;" id="notifDropdown">
                                <li class="dropdown-header fw-bold px-3 py-2 border-bottom">
                                    SLA Breach Alerts (last 1h)
                                </li>
                                <li id="notifEmpty" class="dropdown-item text-muted small py-2">
                                    No alerts — all systems within SLA
                                </li>
                            </ul>
                        </div>
                    </li>
                    <!--end::Notification Bell-->
                    <!--begin::User Menu Dropdown-->
                    <li class="nav-item dropdown user-menu">
                        <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                            <img src="/lib/admin-lte/assets/img/user2-160x160.jpg"
                                 class="user-image rounded-circle shadow"
                                 alt="User Image" />
                            <span class="d-none d-md-inline">Admin</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">
                            <!--begin::User Image-->
                            <li class="user-header text-bg-primary">
                                <img src="/lib/admin-lte/assets/img/user2-160x160.jpg"
                                     class="rounded-circle shadow"
                                     alt="User Image" />
                                <p>
                                    Pankil Desai - Web Developer
                                    <small>Member since Nov. 2023</small>
                                </p>
                            </li>
                            <!--end::User Image-->
                            <!--begin::Menu Footer-->
                            <li class="user-footer">
                                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-default btn-flat float-end">
                                        <i class="fas fa-sign-out-alt me-1"></i> Sign out
                                    </button>
                                </form>
                            </li>
                            <!--end::Menu Footer-->
                        </ul>
                    </li>
                    <!--end::User Menu Dropdown-->
                </ul>
                <!--end::End Navbar Links-->
            </div>
            <!--end::Container-->
        </nav>
        <!--end::Header-->
        <!--begin::Sidebar-->
        <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
            <!--begin::Sidebar Brand-->
            <div class="sidebar-brand">
                <!--begin::Brand Link-->
                <a href="/" class="brand-link">
                    <!--begin::Brand Image-->
                    <img src="/lib/admin-lte/assets/img/AdminLTELogo.png"
                         alt="AdminLTE Logo"
                         class="brand-image opacity-75 shadow" />
                    <!--end::Brand Image-->
                    <!--begin::Brand Text-->
                    <span class="brand-text fw-light">ArNir Admin</span>
                    <!--end::Brand Text-->
                </a>
                <!--end::Brand Link-->
            </div>
            <!--end::Sidebar Brand-->
            <!--begin::Sidebar Wrapper-->
            <div class="sidebar-wrapper">
                <nav class="mt-2">
                    <!--begin::Sidebar Menu-->
                    <ul class="nav sidebar-menu flex-column"
                        data-lte-toggle="treeview"
                        role="navigation"
                        aria-label="Main navigation"
                        data-accordion="false"
                        id="navigation">
                        <li class="nav-item">
                            <a href="/Document" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Document" ? "active" : "")">
                                <i class="nav-icon fas fa-file-alt"></i>
                                <p>Document</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/Embedding" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Embedding" ? "active" : "")">
                                <i class="nav-icon fas fa-search"></i>
                                <p>Embedding Test</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/Retrieval" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Retrieval" ? "active" : "")">
                                <i class="nav-icon fas fa-search"></i>
                                <p>Retrieval Debug</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/RagComparison" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "RagComparison" ? "active" : "")   ">
                                <i class="nav-icon fas fa-project-diagram"></i>
                                <p>RAG Comparison</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/RagHistory" class="nav-link">
                                <i class="nav-icon fas fa-history"></i>
                                <p>RAG History</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/Analytics" class="nav-link">
                                <i class="nav-icon fas fa-chart-bar"></i>
                                <p>Analytics</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/Reports" class="nav-link">
                                <i class="nav-icon fas fa-file-alt"></i>
                                <p>Reports</p>
                            </a>
                        </li>

                        <!-- ── Phase 10 — AI Platform Management ── -->
                        <li class="nav-header">AI PLATFORM</li>
                        <li class="nav-item">
                            <a href="/PromptTemplate" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PromptTemplate" ? "active" : "")">
                                <i class="nav-icon fas fa-brain"></i>
                                <p>Prompt Templates</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/PlatformSettings" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PlatformSettings" ? "active" : "")">
                                <i class="nav-icon fas fa-sliders-h"></i>
                                <p>Platform Settings</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/AgentRunHistory" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AgentRunHistory" ? "active" : "")">
                                <i class="nav-icon fas fa-robot"></i>
                                <p>Agent Run History</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/Evaluation" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Evaluation" ? "active" : "")">
                                <i class="nav-icon fas fa-star-half-alt"></i>
                                <p>Evaluation</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/ObservabilityDashboard" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ObservabilityDashboard" ? "active" : "")">
                                <i class="nav-icon fas fa-chart-line"></i>
                                <p>Observability</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/JobMonitor" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "JobMonitor" ? "active" : "")">
                                <i class="nav-icon fas fa-tasks"></i>
                                <p>Job Monitor</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/Memory" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Memory" ? "active" : "")">
                                <i class="nav-icon fas fa-memory"></i>
                                <p>Memory Sessions</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/VectorStore" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "VectorStore" ? "active" : "")">
                                <i class="nav-icon fas fa-database"></i>
                                <p>Vector Store</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/ProviderConfig" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ProviderConfig" ? "active" : "")">
                                <i class="nav-icon fas fa-key"></i>
                                <p>Provider Config</p>
                            </a>
                        </li>
                    </ul>
                    <!--end::Sidebar Menu-->
                </nav>
            </div>
            <!--end::Sidebar Wrapper-->
        </aside>
        <!--end::Sidebar-->
        <!--begin::App Main-->
        <main class="app-main">
            <!--begin::App Content Header-->
            <div class="app-content-header">
                <!--begin::Container-->
                <div class="container-fluid">
                    <!--begin::Row-->
                    <div class="row">
                        <div class="col-sm-6"><h3 class="mb-0">@ViewData["Title"]</h3></div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
                            </ol>
                        </div>
                    </div>
                    <!--end::Row-->
                </div>
                <!--end::Container-->
            </div>
            <!--end::App Content Header-->
            <!--begin::App Content-->
            <div class="app-content">
                <!--begin::Container-->
                <div class="container-fluid">
                    <!-- /.row (main row) -->
                    @RenderBody()
                </div>
                <!--end::Container-->
            </div>
            <!--end::App Content-->
        </main>
        <!--end::App Main-->
        <!--begin::Footer-->
        <footer class="app-footer">
            <!--begin::To the end-->
            <div class="float-end d-none d-sm-inline">ArNir Enterprise AI Platform v1.0</div>
            <!--end::To the end-->
            <!--begin::Copyright-->
            <strong>
                Copyright &copy; 2014-2025&nbsp;
                <a href="https://adminlte.io" class="text-decoration-none">AdminLTE.io</a>.
            </strong>
            All rights reserved.
            <!--end::Copyright-->
        </footer>
        <!--end::Footer-->
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Bootstrap 5 -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <!-- AdminLTE Scripts -->
    <script src="~/lib/admin-lte/js/adminlte.min.js"></script>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Bootstrap Toast Container -->
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 9999">
        <div id="toastContainer"></div>
    </div>

    <script>
        function showToast(message, type = "success") {
            let bg = type === "success" ? "bg-success" : "bg-danger";
            let icon = type === "success" ? "✔️" : "❌";

            let toast = `
                <div class="toast align-items-center text-white ${bg} border-0 show mb-2" role="alert">
                    <div class="d-flex">
                        <div class="toast-body">${icon} ${message}</div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                </div>
            `;
            $("#toastContainer").append(toast);
            setTimeout(() => $("#toastContainer .toast").first().remove(), 3000);
        }
    </script>

    <script>
        function loadNotifications() {
            fetch('/Notification/GetUnread')
                .then(r => r.json())
                .then(data => {
                    const badge    = document.getElementById('notifBadge');
                    const empty    = document.getElementById('notifEmpty');
                    const dropdown = document.getElementById('notifDropdown');

                    // Update badge
                    if (data.count > 0) {
                        badge.textContent  = data.count;
                        badge.style.display = '';
                    } else {
                        badge.style.display = 'none';
                    }

                    // Remove old alert items (keep header + empty)
                    dropdown.querySelectorAll('.notif-alert-item').forEach(el => el.remove());

                    if (data.count > 0 && data.alerts && data.alerts.length > 0) {
                        empty.style.display = 'none';
                        data.alerts.forEach(a => {
                            const li = document.createElement('li');
                            li.className = 'notif-alert-item';
                            li.innerHTML = `<a class="dropdown-item small py-2 border-bottom" href="#">
                                <span class="text-danger fw-bold">&#9888; SLA Breach</span><br>
                                <span class="text-muted">${a.provider} / ${a.model}</span><br>
                                <span>${a.latencyMs}ms &mdash; ${a.occurredAt}</span>
                            </a>`;
                            dropdown.appendChild(li);
                        });
                    } else {
                        empty.style.display = '';
                    }
                })
                .catch(() => {}); // Silent fail — don't break the UI
        }

        // Poll every 30 seconds
        setInterval(loadNotifications, 30000);
        // Initial load after page is ready
        document.addEventListener('DOMContentLoaded', loadNotifications);
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}