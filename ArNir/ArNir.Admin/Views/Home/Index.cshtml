@model ArNir.Admin.Models.PlatformHealthViewModel
@{
    ViewData["Title"] = "Platform Health Dashboard";
}

<!-- Row 1: Documents, Chunks, Embeddings, PostgreSQL -->
<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-file-alt fa-2x me-3"></i>
                <div>
                    <div class="fs-4 fw-bold">@Model.TotalDocuments</div>
                    <div class="small">Total Documents</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-puzzle-piece fa-2x me-3"></i>
                <div>
                    <div class="fs-4 fw-bold">@Model.TotalChunks</div>
                    <div class="small">Total Chunks</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white @(Model.PostgresConnected ? "bg-success" : "bg-danger")">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-vector-square fa-2x me-3"></i>
                <div>
                    <div class="fs-4 fw-bold">@Model.TotalEmbeddings</div>
                    <div class="small">Total Embeddings</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white @(Model.PostgresConnected ? "bg-success" : "bg-danger")">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-database fa-2x me-3"></i>
                <div>
                    <div class="fs-4 fw-bold">@(Model.PostgresConnected ? "Connected" : "Offline")</div>
                    <div class="small">PostgreSQL</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Row 2: OpenAI Key, Embedder Type, 24h Events, 24h SLA % -->
<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card text-white @(Model.OpenAiKeyConfigured ? "bg-success" : "bg-danger")">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-key fa-2x me-3"></i>
                <div>
                    <div class="fs-5 fw-bold">@(Model.OpenAiKeyConfigured ? "Configured" : "Missing")</div>
                    <div class="small">OpenAI Key</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white @(Model.EmbedderIsReal ? "bg-success" : "bg-warning")">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-robot fa-2x me-3"></i>
                <div>
                    <div class="fs-5 fw-bold">@(Model.EmbedderIsReal ? "Real" : "Stub")</div>
                    <div class="small">Embedder Type</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-chart-bar fa-2x me-3"></i>
                <div>
                    <div class="fs-4 fw-bold">@Model.MetricEventsLast24h</div>
                    <div class="small">24h Events</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white @(Model.SlaComplianceLast24hPct >= 95 ? "bg-success" : Model.SlaComplianceLast24hPct >= 80 ? "bg-warning" : "bg-danger")">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-tachometer-alt fa-2x me-3"></i>
                <div>
                    <div class="fs-4 fw-bold">@Model.SlaComplianceLast24hPct.ToString("F1")%</div>
                    <div class="small">24h SLA %</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Row 3: Recent Agent Runs + 24h Avg Latency -->
<div class="row g-3">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="fas fa-history me-2"></i>Recent Agent Runs</h5>
            </div>
            <div class="card-body">
                <table id="agentRunsTable" class="table table-striped table-sm">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Query</th>
                            <th>Status</th>
                            <th>Started At</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var run in Model.RecentAgentRuns)
                        {
                            <tr>
                                <td class="text-monospace small">@run.Id.ToString("N")[..8]&hellip;</td>
                                <td>@(run.Query.Length > 60 ? run.Query[..60] + "…" : run.Query)</td>
                                <td>
                                    @{
                                        var badgeClass = run.Status switch
                                        {
                                            "Completed" => "bg-success",
                                            "Failed" => "bg-danger",
                                            "Running" => "bg-primary",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@run.Status</span>
                                </td>
                                <td class="small">@run.StartedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                        @if (!Model.RecentAgentRuns.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted">No agent runs yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="fas fa-clock me-2"></i>24h Avg Latency</h5>
            </div>
            <div class="card-body text-center">
                <div class="display-4 fw-bold @(Model.AvgLatencyLast24hMs < 1000 ? "text-success" : Model.AvgLatencyLast24hMs < 3000 ? "text-warning" : "text-danger")">
                    @Model.AvgLatencyLast24hMs.ToString("F0")
                    <small class="fs-6">ms</small>
                </div>
                <p class="text-muted mt-2">Average end-to-end latency over the last 24 hours</p>
                <div class="mt-3">
                    <small class="text-muted">
                        Based on @Model.MetricEventsLast24h metric event(s)
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            if ($('#agentRunsTable tbody tr').length > 1) {
                $('#agentRunsTable').DataTable({ paging: false, searching: false, info: false });
            }
        });
    </script>
}
