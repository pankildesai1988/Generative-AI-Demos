@{
    ViewData["Title"] = "Trigger Agent Run";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-8"><h1 class="m-0">Trigger Agent Run</h1></div>
            <div class="col-sm-4 text-end">
                <a asp-action="Index" asp-controller="AgentRunHistory" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i>Back to History
                </a>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="fas fa-robot me-2"></i>New Agent Run
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="TriggerRun" asp-controller="AgentRunHistory" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="query" class="form-label fw-bold">Query <span class="text-danger">*</span></label>
                        <textarea id="query" name="query" class="form-control @(ViewData.ModelState["query"]?.Errors.Any() == true ? "is-invalid" : "")"
                                  rows="4" placeholder="Enter the natural-language query for the PlannerAgent…" required></textarea>
                        @if (ViewData.ModelState["query"]?.Errors.Any() == true)
                        {
                            <div class="invalid-feedback">
                                @ViewData.ModelState["query"]!.Errors.First().ErrorMessage
                            </div>
                        }
                        <div class="form-text">The agent will decompose this query into a step-by-step plan and execute it.</div>
                    </div>

                    <div class="mb-3">
                        <label for="sessionId" class="form-label fw-bold">Session ID <span class="text-muted">(optional)</span></label>
                        <input type="text" id="sessionId" name="sessionId" class="form-control"
                               placeholder="Leave blank to auto-generate a new session ID" maxlength="64" />
                        <div class="form-text">If blank, a new GUID will be assigned automatically.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-play me-1"></i>Trigger Agent Run
                        </button>
                        <a asp-action="Index" asp-controller="AgentRunHistory" class="btn btn-secondary">
                            <i class="fas fa-times me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
