@model ArNir.Admin.Models.EmbeddingStatsViewModel
@{
    ViewData["Title"] = "Embeddings Management";
}

@if (TempData["Success"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            showToast('@Html.Raw(TempData["Success"])', 'success');
        });
    </script>
}
@if (TempData["Error"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            showToast('@Html.Raw(TempData["Error"])', 'error');
        });
    </script>
}

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-layer-group fa-2x me-3"></i>
                <div>
                    <div class="fs-3 fw-bold">@Model.TotalEmbeddings.ToString("N0")</div>
                    <div class="small">Total Embeddings</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-file-alt fa-2x me-3"></i>
                <div>
                    <div class="fs-3 fw-bold">@Model.TotalDocuments</div>
                    <div class="small">Total Documents</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-brain fa-2x me-3"></i>
                <div>
                    <div class="fs-3 fw-bold">@Model.ByModel.Count</div>
                    <div class="small">Distinct Models</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-secondary">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-clock fa-2x me-3"></i>
                <div>
                    <div class="fs-6 fw-bold">
                        @(Model.OldestCreatedAt.HasValue ? Model.OldestCreatedAt.Value.ToString("yyyy-MM-dd") : "—")
                        →
                        @(Model.NewestCreatedAt.HasValue ? Model.NewestCreatedAt.Value.ToString("yyyy-MM-dd") : "—")
                    </div>
                    <div class="small">Age Range</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Per-Model Table + Rebuild All -->
<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h5 class="card-title mb-0"><i class="fas fa-brain me-2"></i>Embeddings by Model</h5>
            </div>
            <div class="card-body">
                @if (Model.ByModel.Any())
                {
                    <table id="modelTable" class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Model</th>
                                <th class="text-end">Count</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.ByModel)
                            {
                                <tr>
                                    <td><code>@m.Model</code></td>
                                    <td class="text-end fw-bold">@m.Count.ToString("N0")</td>
                                    <td class="text-end">
                                        <button type="button"
                                                class="btn btn-sm btn-danger"
                                                data-model="@m.Model"
                                                onclick="confirmDeleteModel('@m.Model', @m.Count)">
                                            <i class="fas fa-trash me-1"></i>Delete Model
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No embeddings indexed yet.</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="fas fa-sync-alt me-2"></i>Bulk Operations</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">Enqueues all @Model.TotalDocuments document(s) for re-embedding via the background ingestion queue.</p>
                <form id="rebuildAllForm" asp-action="RebuildAll" asp-controller="Embedding" method="post">
                    @Html.AntiForgeryToken()
                    <button type="button" class="btn btn-warning w-100"
                            onclick="confirmRebuildAll(@Model.TotalDocuments)">
                        <i class="fas fa-sync-alt me-1"></i>Rebuild All Embeddings
                    </button>
                </form>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="fas fa-vial me-2"></i>Similarity Test</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small">Run a nearest-neighbour similarity search against the vector store.</p>
                <a href="/Embedding/Test" class="btn btn-info w-100">
                    <i class="fas fa-search me-1"></i>Run Similarity Test
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Generate for document (legacy) -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="fas fa-plus-circle me-2"></i>Generate Embeddings for Document</h5>
    </div>
    <div class="card-body">
        <form asp-action="Generate" asp-controller="Embedding" method="post" class="row g-2">
            @Html.AntiForgeryToken()
            <div class="col-auto">
                <label class="col-form-label">Document ID:</label>
            </div>
            <div class="col-auto">
                <input type="number" name="documentId" class="form-control" placeholder="e.g. 42" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-cogs me-1"></i>Generate
                </button>
            </div>
        </form>
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success mt-3">@TempData["Message"]</div>
        }
    </div>
</div>

<!-- Hidden delete-by-model form -->
<form id="deleteModelForm" asp-action="DeleteByModel" asp-controller="Embedding" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="deleteModelInput" name="model" />
</form>

@section Scripts {
<script>
    function confirmRebuildAll(docCount) {
        Swal.fire({
            title: 'Rebuild All Embeddings?',
            text: `This will enqueue all ${docCount} document(s) for re-embedding. This may take a while.`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d97706',
            confirmButtonText: 'Yes, rebuild all',
            cancelButtonText: 'Cancel'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('rebuildAllForm').submit();
            }
        });
    }

    function confirmDeleteModel(model, count) {
        Swal.fire({
            title: `Delete embeddings for model?`,
            html: `This will permanently delete <strong>${count}</strong> embedding(s) for model <code>${model}</code>.`,
            icon: 'danger',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            confirmButtonText: 'Yes, delete',
            cancelButtonText: 'Cancel'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('deleteModelInput').value = model;
                document.getElementById('deleteModelForm').submit();
            }
        });
    }

    $(document).ready(function () {
        if ($('#modelTable tbody tr').length > 0) {
            $('#modelTable').DataTable({ paging: false, searching: false, info: false });
        }
    });
</script>
}
