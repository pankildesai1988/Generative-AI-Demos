@model ArNir.Admin.Models.ProviderConfigViewModel
@{
    ViewData["Title"] = "Provider Configuration";
}

@if (TempData["Success"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            showToast('@Html.Raw(TempData["Success"])', 'success');
        });
    </script>
}
@if (TempData["Error"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            showToast('@Html.Raw(TempData["Error"])', 'error');
        });
    </script>
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="fas fa-key me-2"></i>OpenAI Configuration
                    @if (Model.OpenAiKeyIsSet)
                    {
                        <span class="badge bg-success ms-2">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger ms-2">Not Configured</span>
                    }
                </h5>
            </div>
            <div class="card-body">

                <!-- OpenAI API Key -->
                <div class="mb-4 border-bottom pb-4">
                    <label class="form-label fw-bold">
                        <i class="fas fa-lock me-1"></i>API Key
                    </label>
                    <p class="text-muted small mb-2">
                        Current value: <code>@Model.OpenAiApiKeyMasked</code>
                    </p>
                    <form asp-controller="ProviderConfig" asp-action="Update" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="key" value="OpenAI:ApiKey" />
                        <div class="input-group">
                            <input type="password"
                                   id="apiKeyInput"
                                   name="value"
                                   class="form-control"
                                   placeholder="sk-..."
                                   autocomplete="new-password" />
                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    onclick="toggleVisibility('apiKeyInput', 'apiKeyEye')">
                                <i id="apiKeyEye" class="fas fa-eye"></i>
                            </button>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>Update
                            </button>
                        </div>
                        <div class="form-text text-warning">
                            <i class="fas fa-exclamation-triangle me-1"></i>
                            The new value will be stored in the database and override the appsettings value.
                        </div>
                    </form>
                </div>

                <!-- Embedding Model -->
                <div class="mb-4 border-bottom pb-4">
                    <label class="form-label fw-bold">
                        <i class="fas fa-brain me-1"></i>Embedding Model
                    </label>
                    <p class="text-muted small mb-2">
                        Current value: <code>@Model.OpenAiEmbeddingModel</code>
                    </p>
                    <form asp-controller="ProviderConfig" asp-action="Update" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="key" value="OpenAI:EmbeddingModel" />
                        <div class="input-group">
                            <input type="text"
                                   name="value"
                                   class="form-control"
                                   value="@Model.OpenAiEmbeddingModel"
                                   placeholder="text-embedding-ada-002" />
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>Update
                            </button>
                        </div>
                        <div class="form-text">
                            Recommended: <code>text-embedding-ada-002</code> or <code>text-embedding-3-small</code>
                        </div>
                    </form>
                </div>

                <!-- Chat Model -->
                <div class="mb-2">
                    <label class="form-label fw-bold">
                        <i class="fas fa-comments me-1"></i>Chat Model
                    </label>
                    <p class="text-muted small mb-2">
                        Current value: <code>@Model.OpenAiChatModel</code>
                    </p>
                    <form asp-controller="ProviderConfig" asp-action="Update" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="key" value="OpenAI:ChatModel" />
                        <div class="input-group">
                            <input type="text"
                                   name="value"
                                   class="form-control"
                                   value="@Model.OpenAiChatModel"
                                   placeholder="gpt-4o-mini" />
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>Update
                            </button>
                        </div>
                        <div class="form-text">
                            Recommended: <code>gpt-4o-mini</code> (fast/cheap) or <code>gpt-4o</code> (high quality)
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="fas fa-info-circle me-2"></i>Notes</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled small text-muted">
                    <li class="mb-2">
                        <i class="fas fa-lock text-warning me-1"></i>
                        API keys are stored in the <code>PlatformSettings</code> database table, not in plain text config files.
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-sync-alt text-info me-1"></i>
                        Changes take effect immediately for new requests (cached values are invalidated).
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-exclamation-circle text-danger me-1"></i>
                        Changing the embedding model requires rebuilding all document embeddings in the Vector Store.
                    </li>
                </ul>
                <a href="/VectorStore" class="btn btn-sm btn-outline-primary w-100 mt-2">
                    <i class="fas fa-database me-1"></i>Go to Vector Store
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleVisibility(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>
}
